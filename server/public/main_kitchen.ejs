<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <script src="js/menu.js"></script>

  <script src="js/jquery-3.7.1.js" integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4=" crossorigin="anonymous"></script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="css/style.css">
  <link rel="stylesheet" href="css/style_for_menu.css">
  <link rel="icon" href="jpgs/favicon.ico">

  <title>Кухня | Cherry Music Bar</title>
</head>

<body>
<script src="js/upMenu.js"></script>

<header id="header">
  <a class="logo" href="/"><img src="../jpgs/logo.png" alt="Logo"></a>
</header>
<%- include('upmenu'); -%>
Десерты
<div class="container mb-5">
  <div class="row">

    <!-- Товары -->
    <div class="col-md-8">
      <div class="row" id="products-container">

        <a href="/main_kitchen/starters" class="col-md-6">
          <div class="card mb-4" data-id="1">
            <img class="product-img" src="./jpgs/dishes/dish.jpg" alt="">
            <div class="card-body text-center">
              <h4 class="item-title">Первое</h4>
            </div>
          </div>
        </a>
        <a href="/main_kitchen/main_dishes" class="col-md-6">
          <div class="card mb-4" data-id="1">
            <img class="product-img" src="./jpgs/dishes/dish.jpg" alt="">
            <div class="card-body text-center">
              <h4 class="item-title">Второе</h4>
            </div>
          </div>
        </a>
        <a href="/main_kitchen/hot_appetizers" class="col-md-6">
          <div class="card mb-4" data-id="1">
            <img class="product-img" src="./jpgs/dishes/dish.jpg" alt="">
            <div class="card-body text-center">
              <h4 class="item-title">Горячие закуски</h4>
            </div>
          </div>
        </a>
        <a href="/main_kitchen/cold_platter" class="col-md-6">
          <div class="card mb-4" data-id="1">
            <img class="product-img" src="./jpgs/dishes/dish.jpg" alt="">
            <div class="card-body text-center">
              <h4 class="item-title">Холодные закуски</h4>
            </div>
          </div>
        </a>
        <a href="/main_kitchen/side_dishes" class="col-md-6">
          <div class="card mb-4" data-id="1">
            <img class="product-img" src="./jpgs/dishes/dish.jpg" alt="">
            <div class="card-body text-center">
              <h4 class="item-title">Гарниры</h4>
            </div>
          </div>
        </a>
        <a href="/main_kitchen/desserts" class="col-md-6">
          <div class="card mb-4" data-id="1">
            <img class="product-img" src="./jpgs/dishes/dish.jpg" alt="">
            <div class="card-body text-center">
              <h4 class="item-title">Десерты</h4>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- Корзина -->
    <div class="col-md-4">

      <!-- Корзина -->
      <div class="mb-4 card">
        <div class="card-body">
          <h4 class="card-title">Ваш заказ</h4>

          <div data-cart-empty="" class="alert alert-secondary none" role="alert">
            Корзина пуста
          </div>

          <!-- cart-wrapper -->
          <div class="cart-wrapper"></div>
          <!-- // cart-wrapper -->

          <!-- Стоимость заказа -->
          <div class="cart-total">
            <p data-cart-delivery class="none">
              <span class="h5">Доставка:</span>
              <span class="delivery-cost">250 ₽</span><br>
            </p>
            <p><span class="h5">Итого:</span>
              <span class="total-price">0</span>
              <span class="rouble">₽</span></p>
          </div>
          <!-- // Стоимость заказа -->

        </div>

        <!-- Оформить заказ -->
        <div id="order-form" class="card-body border-top">
          <h4 class="card-title">Оформить заказ</h4>
          <form>
            <div class="form-group">
              <input type="text" class="form-control" placeholder="Ваш номер телефона">
            </div>
            <button type="submit" class="btn btn-primary">Заказать</button>
          </form>
        </div>
        <!-- // Оформить заказ -->

      </div>
      <!-- // Корзина -->

    </div>

  </div>
</div>


<%- include('footer'); -%>

<script type="text/javascript" src="../js/upMenu.js"></script>
<script type="text/javascript" src="../js/toggleCartStatus.js"></script>
<script type="text/javascript" src="../js/cart.js"></script>
</body>
</html>